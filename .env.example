# zTrade API keys
# Copy this file to .env and replace placeholder values with real keys.
# .env is ignored by Git.

# Polygon.io / Massive.com stock snapshot API
POLYGON_API_KEY=replace-with-your-polygon-or-massive-key

# Optional Finnhub company-news API enrichment
FINNHUB_API_KEY=replace-with-your-finnhub-key

# Optional Tradier option-chain API
TRADIER_TOKEN=replace-with-your-tradier-token

# Optional future Robinhood integration placeholders.
# Live Robinhood trading is intentionally disabled in the current scaffold.
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_SECRET=

# zTrade API keys
# Copy this file to .env and replace placeholder values with real keys.
# .env is ignored by Git.

# Polygon.io / Massive.com stock snapshot API
POLYGON_API_KEY=replace-with-your-polygon-or-massive-key

# Optional Finnhub company-news API enrichment
FINNHUB_API_KEY=replace-with-your-finnhub-key

# Optional Tradier option-chain API
TRADIER_TOKEN=replace-with-your-tradier-token

# IBKR local TWS / IB Gateway connection settings.
# Do not put your IBKR username or password here; log in through TWS or IB Gateway.
# Use paper trading first. TWS paper defaults to 7497; IB Gateway paper defaults to 4002.
# Your screenshot shows TWS socket port 7496, which is the usual live-session default.
# If you keep that port for read-only pricing, set IBKR_PORT=7496 locally and keep live trading disabled.
# Live IBKR trading is intentionally disabled by default.
IBKR_ACCOUNT_ID=
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_USE_TWS_API=true
IBKR_CLIENT_PORTAL_BASE_URL=https://localhost:5000/v1/api
IBKR_LIVE_TRADING_ENABLED=false
